---
interface Props { title: string; }
const { title } = Astro.props;
const path = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} — WattWise</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@300;400;500&display=swap" rel="stylesheet" />
</head>
<body>
  <div class="app-shell">
    <aside class="sidebar">
      <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:1.5rem;">
        <span style="font-size:1.2rem;">⚡</span>
        <span style="font-weight:600;font-size:0.95rem;">WattWise</span>
      </div>

      <nav style="display:flex;flex-direction:column;gap:0.25rem;flex:1;">
        <a href="/" class="nav-item {path === '/' ? 'active' : ''}">
          <span class="nav-icon">◉</span> Dashboard
        </a>
        <a href="/history" class="nav-item {path === '/history' ? 'active' : ''}">
          <span class="nav-icon">↗</span> History
        </a>
        <a href="/optimize" class="nav-item {path === '/optimize' ? 'active' : ''}">
          <span class="nav-icon">✦</span> Optimize
        </a>
        <a href="/settings" class="nav-item {path === '/settings' ? 'active' : ''}">
          <span class="nav-icon">⚙</span> Settings
        </a>
      </nav>

      <div style="margin-top:auto;padding-top:1rem;border-top:1px solid rgba(255,255,255,0.06);">
        <div style="font-size:0.65rem;color:var(--text-quaternary);text-transform:uppercase;letter-spacing:0.08em;margin-bottom:0.35rem;">System</div>
        <div style="font-size:0.75rem;color:var(--text-tertiary);font-family:'JetBrains Mono',monospace;" id="sidebar-status">Connecting...</div>
      </div>
    </aside>

    <main class="main-content">
      <slot />
    </main>
  </div>

  <script>
    let _consecutiveFailures = 0;
    window.__SENSOR_ONLINE__ = false;

    async function checkHealth() {
      try {
        const r = await fetch('http://localhost:45892/api/health');
        if (r.ok) {
          _consecutiveFailures = 0;
          window.__SENSOR_ONLINE__ = true;
          document.getElementById('sidebar-status')!.textContent = '● Live';
          document.getElementById('sidebar-status')!.style.color = 'rgb(34,197,94)';
        }
      } catch {
        _consecutiveFailures++;
        if (_consecutiveFailures >= 3) {
          window.__SENSOR_ONLINE__ = false;
        }
        document.getElementById('sidebar-status')!.textContent = '○ Offline';
        document.getElementById('sidebar-status')!.style.color = 'rgb(239,68,68)';
      }
    }
    checkHealth();
    setInterval(checkHealth, 5000);
  </script>
</body>
</html>
