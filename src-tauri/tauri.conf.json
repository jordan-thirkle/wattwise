{
  "$schema": "https://raw.githubusercontent.com/jordan-thirkle/wattwise/main/schema.json",
  "productName": "WattWise",
  "version": "1.0.0",
  "identifier": "com.byjtt.wattwise",
  "build": {
    "frontendDist": "../frontend/dist",
    "devUrl": "http://localhost:4321",
    "beforeDevCommand": "npm --prefix ../frontend run dev",
    "beforeBuildCommand": "powershell -NoLogo -NoProfile -ExecutionPolicy Bypass -File ../build.ps1"
  },
  "app": {
    "windows": [
      {
        "title": "WattWise",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src http://localhost:45892; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/wattwise-sensor"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "sidecar": true,
      "scope": [
        {
          "name": "wattwise-sensor",
          "sidecar": true
        }
      ]
    }
  }
}
