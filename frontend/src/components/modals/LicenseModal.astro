<div id="license-modal" style="position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(10,10,12,0.92);display:none;align-items:center;justify-content:center;z-index:300;">
  <div class="card" style="max-width:440px;width:100%;padding:2rem;">
    <!-- Trial mode -->
    <div id="lm-trial" style="display:none;">
      <h2 style="font-size:1.25rem;font-weight:600;margin-bottom:0.5rem;">7-Day Free Trial</h2>
      <p style="color:var(--accent-secondary);font-size:0.85rem;margin-bottom:1rem;"><span id="lm-days">7</span> days remaining</p>
      <div style="margin-bottom:1rem;">
        <label class="label" for="lm-key">Licence Key</label>
        <input type="text" id="lm-key" class="input" placeholder="Paste your Gumroad licence key" />
      </div>
      <button id="lm-activate" class="btn-primary" style="width:100%;justify-content:center;margin-bottom:0.5rem;">Activate Licence</button>
      <button id="lm-continue" class="btn-secondary" style="width:100%;justify-content:center;margin-bottom:0.5rem;">Continue Trial</button>
      <a href="#" id="lm-buy" class="btn-ghost" style="width:100%;justify-content:center;display:flex;">Buy Licence — £4.99</a>
    </div>
    <!-- Expired mode -->
    <div id="lm-expired" style="display:none;">
      <h2 style="font-size:1.25rem;font-weight:600;margin-bottom:0.5rem;color:var(--error);">Trial Ended</h2>
      <p style="color:var(--text-secondary);font-size:0.85rem;line-height:1.6;margin-bottom:1rem;">Your 7-day trial has expired. Purchase a licence to continue monitoring your power usage.</p>
      <div style="margin-bottom:1rem;">
        <label class="label" for="lm-key-exp">Licence Key</label>
        <input type="text" id="lm-key-exp" class="input" placeholder="Paste your Gumroad licence key" />
      </div>
      <button id="lm-activate-exp" class="btn-primary" style="width:100%;justify-content:center;margin-bottom:0.5rem;">Activate Licence</button>
      <a href="#" id="lm-buy-exp" class="btn-primary" style="width:100%;justify-content:center;display:flex;">Buy Licence — £4.99</a>
    </div>
    <p id="lm-status" style="font-size:0.7rem;margin-top:0.75rem;text-align:center;display:none;"></p>
  </div>
</div>

<script>
  import { validateLicenseKey, fetchLicenseStatus } from '../../lib/api';

  function setStatus(msg: string, ok: boolean) {
    const el = document.getElementById('lm-status')!;
    el.textContent = msg;
    el.style.color = ok ? 'var(--accent-secondary)' : 'var(--error)';
    el.style.display = 'block';
  }

  document.getElementById('lm-activate')?.addEventListener('click', async () => {
    const key = (document.getElementById('lm-key') as HTMLInputElement).value.trim();
    if (!key) { setStatus('Please enter a licence key.', false); return; }
    setStatus('Validating...', true);
    try {
      const result = await validateLicenseKey(key);
      if (result.valid) {
        setStatus('Licence activated successfully!', true);
        setTimeout(() => { document.getElementById('license-modal')!.style.display = 'none'; }, 1500);
      } else {
        setStatus(result.message, false);
      }
    } catch {
      setStatus('Failed to reach the licence server.', false);
    }
  });

  document.getElementById('lm-activate-exp')?.addEventListener('click', async () => {
    const key = (document.getElementById('lm-key-exp') as HTMLInputElement).value.trim();
    if (!key) { setStatus('Please enter a licence key.', false); return; }
    setStatus('Validating...', true);
    try {
      const result = await validateLicenseKey(key);
      if (result.valid) {
        setStatus('Licence activated successfully!', true);
        setTimeout(() => { document.getElementById('license-modal')!.style.display = 'none'; }, 1500);
      } else {
        setStatus(result.message, false);
      }
    } catch {
      setStatus('Failed to reach the licence server.', false);
    }
  });

  document.getElementById('lm-continue')?.addEventListener('click', () => {
    document.getElementById('license-modal')!.style.display = 'none';
  });

  window.showLicenseModal = function(state: string, daysRemaining: number) {
    const modal = document.getElementById('license-modal')!;
    modal.style.display = 'flex';
    const trialDiv = document.getElementById('lm-trial')!;
    const expiredDiv = document.getElementById('lm-expired')!;
    const daysEl = document.getElementById('lm-days')!;
    if (state === 'trial') {
      trialDiv.style.display = 'block';
      expiredDiv.style.display = 'none';
      daysEl.textContent = daysRemaining.toString();
      const color = daysRemaining <= 3 ? 'var(--warning)' : 'var(--accent-secondary)';
      daysEl.parentElement!.style.color = color;
    } else {
      trialDiv.style.display = 'none';
      expiredDiv.style.display = 'block';
    }
  };

  declare global {
    interface Window {
      showLicenseModal: (state: string, daysRemaining: number) => void;
    }
  }
</script>
