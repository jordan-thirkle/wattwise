---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Settings">
  <div style="margin-bottom:1.5rem;">
    <h1 style="font-size:1.5rem;font-weight:600;">Settings</h1>
    <p style="color:var(--text-tertiary);font-size:0.8rem;margin-top:0.15rem;">Customize your electricity rate and preferences</p>
  </div>

  <div class="card" style="max-width:500px;margin-bottom:1rem;">
    <div style="margin-bottom:1rem;">
      <label class="label" for="rate">Electricity Rate (p/kWh)</label>
      <input type="number" id="rate" class="input" step="0.01" placeholder="23.09" />
      <p style="color:var(--text-quaternary);font-size:0.65rem;margin-top:0.25rem;">Check your energy bill for your unit rate</p>
    </div>
    <div style="margin-bottom:1rem;">
      <label class="label" for="standing">Standing Charge (p/day)</label>
      <input type="number" id="standing" class="input" step="0.01" placeholder="64.29" />
    </div>
    <div style="margin-bottom:1rem;">
      <label class="label" for="currency">Currency</label>
      <select id="currency" class="input">
        <option value="GBP">GBP (£)</option>
        <option value="USD">USD ($)</option>
        <option value="EUR">EUR (€)</option>
      </select>
    </div>
    <div style="margin-bottom:1rem;">
      <label class="label" for="baseWatts">Base System Wattage (RAM, drives, fans)</label>
      <input type="number" id="baseWatts" class="input" placeholder="45" />
      <p style="color:var(--text-quaternary);font-size:0.65rem;margin-top:0.25rem;">Estimated background draw. Use a smart plug for exact measurement.</p>
    </div>
    <div style="margin-bottom:1rem;">
      <label class="label" for="retention">Data Retention (days)</label>
      <input type="number" id="retention" class="input" placeholder="90" />
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;">
      <button id="save-btn" class="btn-primary">Save Settings</button>
      <span id="save-status" style="font-size:0.7rem;color:var(--accent-secondary);font-family:'JetBrains Mono',monospace;display:none;">Saved</span>
    </div>
  </div>

  <div class="card" style="max-width:500px;margin-bottom:1rem;">
    <h3 style="font-size:0.85rem;font-weight:600;margin-bottom:0.75rem;">Licence</h3>
    <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.5rem;">
      <span style="font-size:0.75rem;color:var(--text-tertiary);">Status:</span>
      <span id="lic-status" class="badge-active" style="font-size:0.65rem;">Loading...</span>
    </div>
    <p id="lic-email" style="font-size:0.65rem;color:var(--text-tertiary);font-family:'JetBrains Mono',monospace;margin-bottom:1rem;display:none;"></p>
    <div id="lic-trial-actions" style="display:none;margin-bottom:0.75rem;">
      <button id="lic-start-trial" class="btn-primary">Start 7-Day Free Trial</button>
    </div>
    <div style="margin-bottom:0.75rem;">
      <label class="label" for="lic-key">Licence Key</label>
      <input type="text" id="lic-key" class="input" placeholder="Paste your Gumroad licence key" />
    </div>
    <div style="display:flex;gap:0.75rem;align-items:center;margin-bottom:0.75rem;">
      <button id="lic-activate" class="btn-secondary">Activate</button>
      <span id="lic-result" style="font-size:0.7rem;font-family:'JetBrains Mono',monospace;display:none;"></span>
    </div>
    <a href="https://jordanthirkle.gumroad.com/l/wattwise" target="_blank" rel="noopener noreferrer" id="lic-buy" class="btn-ghost" style="display:inline-flex;">Buy Licence — £4.99</a>
    <p style="color:var(--text-quaternary);font-size:0.6rem;margin-top:0.6rem;line-height:1.4;">WattWise Pro is £4.99 one-time. It funds development and keeps the free tier ad-free forever.</p>
  </div>

  <div class="card" style="max-width:500px;">
    <h3 style="font-size:0.85rem;font-weight:600;margin-bottom:0.75rem;">About WattWise</h3>
    <div style="color:var(--text-secondary);font-size:0.8rem;line-height:1.6;">
      <p>v1.0.1 &middot; Built with <a href="https://ui.byjtt.com" target="_blank" rel="noopener noreferrer" style="color:var(--accent-primary);">ByJT UI</a></p>
      <p style="margin-top:0.35rem;">Sensors powered by <a href="https://github.com/LibreHardwareMonitor/LibreHardwareMonitor" target="_blank" rel="noopener noreferrer" style="color:var(--accent-primary);">LibreHardwareMonitor</a></p>
      <p style="margin-top:0.35rem;">
        <a href="https://github.com/jordan-thirkle/wattwise" target="_blank" rel="noopener noreferrer" style="color:var(--text-tertiary);font-size:0.7rem;">GitHub</a>
        &middot;
        <a href="https://byjtt.com/projects" target="_blank" rel="noopener noreferrer" style="color:var(--text-tertiary);font-size:0.7rem;">byjtt.com</a>
      </p>
    </div>
  </div>
</Layout>

<script>
  import { fetchSettings, updateSettings, fetchLicenseStatus, validateLicenseKey, startTrial } from '../lib/api';

  async function loadSettings() {
    try {
      const s = await fetchSettings();
      (document.getElementById('rate') as HTMLInputElement).value = s.ratePencePerKwh || 23.09;
      (document.getElementById('standing') as HTMLInputElement).value = s.standingChargePencePerDay || 64.29;
      (document.getElementById('currency') as HTMLSelectElement).value = s.currency || 'GBP';
      (document.getElementById('baseWatts') as HTMLInputElement).value = s.baseSystemWatts || 45;
      (document.getElementById('retention') as HTMLInputElement).value = s.dataRetentionDays || 90;
    } catch {
      document.getElementById('save-status')!.textContent = 'Backend offline';
      document.getElementById('save-status')!.style.color = 'var(--error)';
      document.getElementById('save-status')!.style.display = 'block';
    }
  }

  document.getElementById('save-btn')!.addEventListener('click', async () => {
    const rate = parseFloat((document.getElementById('rate') as HTMLInputElement).value);
    const standing = parseFloat((document.getElementById('standing') as HTMLInputElement).value);
    const baseWatts = parseInt((document.getElementById('baseWatts') as HTMLInputElement).value);
    const retention = parseInt((document.getElementById('retention') as HTMLInputElement).value);

    if (isNaN(rate) || rate <= 0 || isNaN(standing) || standing < 0 || isNaN(baseWatts) || baseWatts < 0 || isNaN(retention) || retention < 1) {
      const status = document.getElementById('save-status')!;
      status.textContent = 'Please enter valid positive numbers';
      status.style.color = 'var(--error)';
      status.style.display = 'block';
      return;
    }

    const settings = {
      ratePencePerKwh: rate,
      standingChargePencePerDay: standing,
      currency: (document.getElementById('currency') as HTMLSelectElement).value,
      baseSystemWatts: baseWatts,
      updateIntervalMs: 1000,
      dataRetentionDays: retention,
    };
    try {
      await updateSettings(settings);
      const status = document.getElementById('save-status')!;
      status.textContent = 'Saved';
      status.style.color = 'var(--success)';
      status.style.display = 'block';
      setTimeout(() => { status.style.display = 'none'; }, 3000);
    } catch {
      const status = document.getElementById('save-status')!;
      status.textContent = 'Failed to save';
      status.style.color = 'var(--error)';
      status.style.display = 'block';
    }
  });

  loadSettings();

  // Licence section
  let currentLicenseState = '';

  async function loadLicense() {
    try {
      const s = await fetchLicenseStatus();
      currentLicenseState = s.state;
      const badge = document.getElementById('lic-status')!;
      const trialActions = document.getElementById('lic-trial-actions')!;
      const email = document.getElementById('lic-email')!;

      if (s.state === 'active') {
        badge.textContent = 'ACTIVE';
        badge.className = 'badge-active';
        trialActions.style.display = 'none';
        if (s.email) { email.textContent = s.email; email.style.display = 'block'; }
      } else if (s.state === 'trial') {
        badge.textContent = `TRIAL — ${s.daysRemaining}d remaining`;
        badge.className = 'badge-active';
        trialActions.style.display = 'none';
        email.style.display = 'none';
      } else {
        badge.textContent = 'FREE';
        badge.className = 'badge-paused';
        trialActions.style.display = 'block';
        email.style.display = 'none';
      }
    } catch {
      const badge = document.getElementById('lic-status')!;
      badge.textContent = 'OFFLINE';
      badge.className = 'badge-error';
    }
  }

  document.getElementById('lic-activate')!.addEventListener('click', async () => {
    const key = (document.getElementById('lic-key') as HTMLInputElement).value.trim();
    const resultEl = document.getElementById('lic-result')!;
    if (!key) {
      resultEl.textContent = 'Please enter a licence key.';
      resultEl.style.color = 'var(--error)';
      resultEl.style.display = 'block';
      return;
    }
    resultEl.textContent = 'Validating...';
    resultEl.style.color = 'var(--text-tertiary)';
    resultEl.style.display = 'block';
    try {
      const result = await validateLicenseKey(key);
      resultEl.textContent = result.message;
      resultEl.style.color = result.valid ? 'var(--accent-secondary)' : 'var(--error)';
      if (result.valid) {
        loadLicense();
        setTimeout(() => { resultEl.style.display = 'none'; }, 5000);
      }
    } catch {
      resultEl.textContent = 'Cannot reach licence server.';
      resultEl.style.color = 'var(--error)';
    }
  });

  document.getElementById('lic-start-trial')?.addEventListener('click', async () => {
    const resultEl = document.getElementById('lic-result')!;
    resultEl.textContent = 'Starting trial...';
    resultEl.style.color = 'var(--text-tertiary)';
    resultEl.style.display = 'block';
    try {
      const status = await startTrial();
      if (status.state === 'trial') {
        resultEl.textContent = 'Trial started! 7 days of Pro features unlocked.';
        resultEl.style.color = 'var(--accent-secondary)';
        loadLicense();
      } else {
        resultEl.textContent = 'Already on a trial or active licence.';
        resultEl.style.color = 'var(--warning)';
      }
    } catch {
      resultEl.textContent = 'Failed to start trial.';
      resultEl.style.color = 'var(--error)';
    }
  });

  loadLicense();
</script>
