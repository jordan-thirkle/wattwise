---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Optimize">
  <div style="margin-bottom:1.5rem;">
    <h1 style="font-size:1.5rem;font-weight:600;">Optimize</h1>
    <p style="color:var(--text-tertiary);font-size:0.8rem;margin-top:0.15rem;">AI-powered suggestions to reduce your electricity bill</p>
  </div>

  <div id="suggestions-container">
    <div class="card" style="text-align:center;padding:2rem;color:var(--text-tertiary);">
      Analyzing your usage patterns...
    </div>
  </div>
</Layout>

<script>
  import { fetchSuggestions, fetchSummary } from '../lib/api';

  const actionIcons: Record<string, string> = {
    powercfg: '⚙',
    settings: '⏱',
    info: '💡',
    link: '🔗',
  };

  async function loadOptimizations() {
    const container = document.getElementById('suggestions-container')!;
    try {
      const summary = await fetchSummary();
      const response = await fetchSuggestions();
      const suggestions = response.suggestions || [];
      const upgradeHint = response.upgradeHint;

      container.innerHTML = `
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:0.75rem;margin-bottom:1rem;">
          <div class="stat-card"><span class="stat-value text-warning">${summary.idleHoursToday}h</span><span class="stat-label">Idle Today</span></div>
          <div class="stat-card"><span class="stat-value text-error">£${summary.idleCostToday.toFixed(3)}</span><span class="stat-label">Idle Cost Today</span></div>
          <div class="stat-card"><span class="stat-value" style="color:var(--accent-primary);">${summary.avgWattsToday}W</span><span class="stat-label">Avg Draw Today</span></div>
        </div>
      `;

      if (upgradeHint) {
        const idleCost = summary.idleCostToday || 0;
        const idleHrs = summary.idleHoursToday || 0;
        const avgWatts = summary.avgWattsToday || 0;
        container.innerHTML += `
          <div class="card" style="text-align:center;padding:1.75rem;border-color:rgba(99,102,241,0.25);margin-bottom:0.75rem;">
            <span class="badge-active" style="margin-bottom:0.5rem;display:inline-block;">Pro Feature</span>
            <h3 style="font-size:1.1rem;font-weight:600;margin-bottom:0.5rem;">Optimization Engine</h3>
            <p style="color:var(--text-secondary);font-size:0.85rem;line-height:1.6;margin-bottom:1.25rem;">AI-powered analysis that finds exactly where your electricity money is going — and fixes it in one click.</p>
            <div style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;margin-bottom:0.75rem;">
              <a href="/settings" class="btn-primary" style="font-size:0.8rem;text-decoration:none;">Start 7-Day Free Trial</a>
              <a href="/settings" class="btn-secondary" style="font-size:0.8rem;text-decoration:none;">Buy Pro £4.99</a>
            </div>
          </div>
          ${idleHrs > 0 ? `
          <div class="card" style="text-align:center;padding:1rem;border-color:rgba(255,255,255,0.05);margin-bottom:0.75rem;">
            <p style="color:var(--text-tertiary);font-size:0.8rem;line-height:1.5;">
              <span style="color:var(--text-secondary);">Your PC idled for <strong style="color:var(--warning);">${idleHrs}h</strong> today at ~<strong style="color:var(--text-primary);">${avgWatts}W</strong>, costing <strong style="color:var(--error);">£${idleCost.toFixed(3)}</strong>.</span><br/>
              <span style="color:var(--accent-secondary);">Pro would detect this automatically and suggest a fix.</span>
            </p>
          </div>
          ` : `
          <div class="card" style="text-align:center;padding:1rem;border-color:rgba(255,255,255,0.05);margin-bottom:0.75rem;">
            <p style="color:var(--text-tertiary);font-size:0.8rem;line-height:1.5;">
              <span style="color:var(--text-secondary);">Pro scans your usage patterns and finds specific ways to save — like enabling aggressive hibernate during idle hours, or flagging background apps that keep your CPU awake.</span>
            </p>
          </div>
          `}
        `;
        return;
      }

      if (suggestions.length === 0) {
        container.innerHTML += '<div class="card" style="text-align:center;padding:2rem;color:var(--accent-secondary);">Your system is already optimized. No savings found!</div>';
        return;
      }

      const cards = suggestions.map((s: any) => `
        <div class="card card-hover" style="margin-bottom:0.75rem;display:flex;align-items:flex-start;gap:1rem;">
          <div style="font-size:1.5rem;flex-shrink:0;width:2.5rem;height:2.5rem;display:flex;align-items:center;justify-content:center;background:rgba(255,255,255,0.04);border-radius:8px;">
            ${actionIcons[s.actionType] || '✦'}
          </div>
          <div style="flex:1;">
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:0.35rem;">
              <h3 style="font-size:0.9rem;font-weight:600;">${s.title}</h3>
              <span class="badge-active" style="font-size:0.55rem;">Save £${s.estimatedMonthlySaving.toFixed(2)}/mo</span>
            </div>
            <p style="color:var(--text-secondary);font-size:0.78rem;line-height:1.5;margin-bottom:0.75rem;">${s.description}</p>
            ${s.actionCommand.startsWith('http') ? 
              `<a href="${s.actionCommand}" target="_blank" class="btn-secondary" style="font-size:0.7rem;padding:0.3rem 0.75rem;">Learn More</a>` :
              s.actionType === 'info' ?
              `<span class="badge-pending">Manual action required</span>` :
              `<button class="btn-primary" style="font-size:0.7rem;padding:0.3rem 0.75rem;" onclick="applyFix('${s.id}')">Apply Fix</button>`
            }
          </div>
        </div>
      `).join('');

      container.innerHTML += cards;
    } catch (e) {
      container.innerHTML = '<div class="card" style="text-align:center;padding:2rem;color:var(--error);">Backend offline — start wattwise-sensor.exe to analyze</div>';
    }
  }

  loadOptimizations();
</script>
